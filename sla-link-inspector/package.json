{
  "name": "linked-sla-alerts-forge",
  "version": "1.1.15",
  "main": "index.js",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js src",
    "build": "node scripts/bundle-frontend.js",
    "scan:sast": "npm run lint",
    "scan:sca": "npm audit --audit-level=high",
    "scan:deps": "npm outdated",
    "scan:all": "npm run scan:sast && npm run scan:sca && npm run scan:deps",
    "predeploy": "npm run build",
    "deploy": "forge deploy -e production",
    "deploy:dev": "npm run build && forge deploy -e development",
    "deploy:production": "npm run deploy"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^3.0.1"
  },
  "overrides": {
    "lodash": "^4.18.1"
  },
  "dependencies": {
    "@forge/api": "^7.0.0",
    "@forge/bridge": "^5.2.0",
    "@forge/kvs": "^1.4.0",
    "@forge/react": "^11.14.0",
    "@forge/resolver": "^1.7.1",
    "react": "^18.2.0"
  }
}
